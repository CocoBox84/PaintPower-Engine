<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:explorer="clr-namespace:PaintPower.FileExplorer"
        xmlns:editors="clr-namespace:PaintPower.Editors"
        xmlns:vm="clr-namespace:PaintPower.VMPanel"
        x:Class="PaintPower.MainWindow"
        Width="1280" Height="720"
        Title="PaintPower">

	<Grid ColumnDefinitions="260,*,300">

		<!-- LEFT: File Explorer -->
		<explorer:ExplorerView x:Name="Explorer" Grid.Column="0"/>

		<!-- CENTER: Editor Host -->
		<ContentControl x:Name="EditorHost"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>

		<!-- RIGHT: VM Panel -->
		<vm:VmPanel Grid.Column="2"/>

	</Grid>
</Window>