<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PaintPower.FileExplorer.ExplorerView">

	<Grid RowDefinitions="Auto,Auto,*" Margin="8">

		<!-- Toolbar -->
		<StackPanel Orientation="Horizontal" Spacing="6">
			<Button Content="New" Click="OnNewFile"/>
			<Button Content="New Folder" Click="OnNewFolder"/>
			<Button Content="/" Click="OnGoRoot"/>
			<Button Content=".." Click="OnGoUp"/>
		</StackPanel>

		<!-- Current Path -->
		<TextBlock x:Name="PathLabel"
                   Grid.Row="1"
                   FontSize="14"
                   Margin="4"/>

		<!-- File List -->
		<ListBox x:Name="FileList"
                 Grid.Row="2"
                 DoubleTapped="OnItemDoubleTapped"
                 SelectionChanged="OnSelectionChanged"/>
	</Grid>
</UserControl>