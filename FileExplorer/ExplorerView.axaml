<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PaintPower.FileExplorer.ExplorerView">

	<Border Background="#99000000">
		<Grid RowDefinitions="Auto,Auto,*" Margin="8">

			<!-- Toolbar -->
			<StackPanel Orientation="Horizontal" Spacing="6">
				<Button x:Name="NewFileButton" Classes="white" Content="New" Click="OnNewFile"/>
				<Button x:Name="NewFolderButton" Classes="white" Content="New Folder" Click="OnNewFolder"/>
				<Button x:Name="GoRootButton" Classes="white" Content="Go to Root" Click="OnGoRoot"/>
				<Button x:Name="GoUpButton" Classes="white" Content="Go Up" Click="OnGoUp"/>
			</StackPanel>

			<!-- Current Path -->
			<TextBlock x:Name="PathLabel"
                       Grid.Row="1"
                       FontSize="14"
                       Margin="4"
                       Foreground="White"/>

			<!-- File List -->
			<Border Background="#20202020" Grid.Row="2">
				<ListBox x:Name="FileList"
                         DoubleTapped="OnItemDoubleTapped"
                         SelectionChanged="OnSelectionChanged"/>
			</Border>

		</Grid>
	</Border>
</UserControl>