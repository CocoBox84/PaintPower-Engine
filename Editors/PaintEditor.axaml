<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PaintPower.Editors.PaintEditor"
			 xmlns:local="clr-namespace:PaintPower.Editors">

	<Grid RowDefinitions="60,*">

		<Rectangle Fill="#80000000"
				   Grid.RowSpan="2"
				   IsHitTestVisible="False"/>

		<!-- TOP TOOLBAR -->
		<StackPanel Grid.Row="0"
					Orientation="Horizontal"
					Background="#e0e0e0"
					VerticalAlignment="Center"
					HorizontalAlignment="Left"
					Spacing="16"
					Margin="12">
			<Button x:Name="UndoButton" Content="Undo" Width="80"/>
			<Button x:Name="SaveButton" Content="Save" Width="80"/>
			<Button x:Name="ClearButton" Content="Clear" Width="80"/>
			<Button x:Name="RedoButton" Content="Redo" Width="80"/>
		</StackPanel>

		<!-- 3-COLUMN AREA -->
		<Grid Grid.Row="1" ColumnDefinitions="220,*,220">

			<!-- LEFT COLUMN -->
			<Border Grid.Column="0"
					Background="#303030"
					Padding="8">
				<StackPanel Spacing="12"
							VerticalAlignment="Top">
					<Button x:Name="AddLayerButton" Content="Add Layer" Margin="0,8,0,0"/>
					<Button x:Name="DeleteLayerButton" Content="Delete Layer"/>
					<ListBox x:Name="LayersList"
         Background="#303030"
         BorderThickness="0"
         Foreground="White">
						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="local:Layer">
								<StackPanel Orientation="Horizontal" Spacing="8">
									<CheckBox IsChecked="{Binding Visible}" VerticalAlignment="Center"/>

									<Image Source="{Binding Thumbnail}"
										   Width="40" Height="40"
										   Stretch="Uniform"
										   Margin="4"/>

									<StackPanel>
										<TextBlock Text="{Binding Name}" Foreground="White"/>
										<Slider Minimum="0" Maximum="1"
												Value="{Binding Opacity}"
												Width="60"/>
									</StackPanel>
								</StackPanel>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</StackPanel>
			</Border>

			<!-- CENTER COLUMN: CANVAS WITH VIEWPORT -->
			<Border Grid.Column="1"
					Margin="8"
					Background="Cyan">

				<Grid>

					<!-- Scrollable zoomable canvas -->
					<ScrollViewer x:Name="CanvasScroll"
						  HorizontalScrollBarVisibility="Auto"
						  VerticalScrollBarVisibility="Auto">
						<LayoutTransformControl x:Name="ZoomContainer">
							<Image x:Name="CanvasImage"
								   Stretch="None"
								   HorizontalAlignment="Left"
								   VerticalAlignment="Top"/>
						</LayoutTransformControl>
					</ScrollViewer>

					<local:PixelGrid x:Name="pixelGrid"
                 IsHitTestVisible="False"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"/>

					<!-- Floating zoom controls -->
					<Border Background="#80000000"
							Padding="6"
							CornerRadius="4"
							HorizontalAlignment="Left"
							VerticalAlignment="Bottom"
							Margin="10">
						<StackPanel Orientation="Horizontal"
									Spacing="8">

							<TextBlock Text="Zoom"
									   Foreground="White"
									   VerticalAlignment="Center"/>

							<Slider x:Name="ZoomSlider"
									Minimum="0.1"
									Maximum="8"
									Value="1"
									Width="150"/>

						</StackPanel>
					</Border>

				</Grid>
			</Border>

			<!-- RIGHT COLUMN -->
			<Border Grid.Column="2"
					Background="#e0e0e0"
					Padding="12">
				<StackPanel Spacing="12"
							VerticalAlignment="Top">

					<TextBlock Text="Brush Size" />
					<Slider x:Name="BrushSizeSlider"
							Minimum="1" Maximum="50"
							Width="150"
							Value="8"/>

					<TextBlock Text="Color" />

					<Border Background="White"
							CornerRadius="4"
							Padding="4">
						<ItemsControl x:Name="ColorSwatches">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Orientation="Horizontal"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>

							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Width="24" Height="24"
											Background="{Binding}"
											CornerRadius="4"
											Margin="2"
											BorderBrush="Black"
											BorderThickness="1"
											PointerPressed="OnSwatchClicked"/>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Border>

					<Button x:Name="BrushButton" Content="Brush" Width="150"/>
					<Button x:Name="EraserButton" Content="Eraser" Width="150"/>
					<Button x:Name="HandToolButton" Content="Hand Tool" Width="150"/>
					<Button x:Name="BucketButton" Content="Bucket" Width="150"/>

				</StackPanel>
			</Border>

		</Grid>
	</Grid>
</UserControl>