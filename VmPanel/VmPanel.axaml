<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PaintPower.VMPanel.VmPanel">
	<Grid>
		<Grid.Background>
			<ImageBrush Source="avares://PaintPower/Assets/Background Dark.png"
						Stretch="None"
						TileMode="Tile"
						DestinationRect="0,0,10,10" />
		</Grid.Background>

		<Rectangle Fill="#80000000"/>
		<Border Padding="10">
			<StackPanel>
				<TextBlock x:Name="VMPanelText" Text="VM Panel"
						   FontSize="20"
						   Foreground="White"
						   Margin="0 0 0 10"/>
				<Border Width="300" Height="300"  BorderBrush="gray" Background="white" BorderThickness="3" CornerRadius="8" Padding="10"/>
				<StackPanel Orientation="Horizontal">
					<Button x:Name="PlayButton" Classes="gray" Content="Play" Margin="0 5"/>
					<Button x:Name="StopButton" Classes="gray" Content="Stop" Margin="0 5"/>
					<Button x:Name="BuildAndRunButton" Classes="gray" Content="Build and Run" Margin="0 5"/>
				</StackPanel>
			</StackPanel>
		</Border>
	</Grid>

</UserControl>